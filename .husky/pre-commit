#!/bin/sh
# Pre-commit hook — runs lint-staged (ESLint) + vitest unit tests.
# Playwright e2e moved to pre-push to avoid Turbopack cold-compile stalls
# blocking rapid commits. See .husky/pre-push.

# ── Mechanical gate: migration files require SCHEMA_SNAPSHOT.md update ──
# Per CLAUDE.md "After EVERY confirmed successful migration → update snapshot."
# Repeated skips of this rule (4+ times by Session 77) prompted this gate.
# It catches at minimum the changelog entry. Structured-table regen still
# requires a separate REFRESH_SCHEMA.sql run.
STAGED=$(git diff --cached --name-only)
if echo "$STAGED" | grep -qE "^supabase/migrations/.*\.sql$"; then
  if ! echo "$STAGED" | grep -qE "^supabase/SCHEMA_SNAPSHOT\.md$"; then
    echo ""
    echo "❌ ERROR: Migration file staged without SCHEMA_SNAPSHOT.md update."
    echo ""
    echo "   Migration files in this commit:"
    echo "$STAGED" | grep -E "^supabase/migrations/.*\.sql$" | sed 's/^/     /'
    echo ""
    echo "   Per CLAUDE.md, every migration requires at minimum:"
    echo "     1. A changelog entry in supabase/SCHEMA_SNAPSHOT.md"
    echo "        (date + migration filename + what changed)"
    echo "     2. Updated function descriptions if any function logic changed"
    echo "     3. Structured-table regen if columns/tables/FKs/indexes changed"
    echo "        (run supabase/REFRESH_SCHEMA.sql, paste output, rebuild tables)"
    echo ""
    echo "   Stage the snapshot edit + retry the commit."
    echo "   Bypass (rare — emergency fixes only): git commit --no-verify"
    echo ""
    exit 1
  fi
fi

# ── Mechanical gate: amend-of-pushed-commit (heuristic for `git commit --amend -m`) ──
# Per apps/web/.claude/rules/git-and-deployment.md Rule 3.
# prepare-commit-msg catches most amend modes via $2="commit", but cannot
# distinguish `git commit --amend -m "..."` from a plain commit. Heuristic:
# amend preserves the original commit's author date in GIT_AUTHOR_DATE. If
# that matches HEAD's author date AND HEAD is on a remote, it's almost
# certainly an amend. False positive: two real commits within the same
# second targeting a pushed commit. Essentially never.
if [ -n "$GIT_AUTHOR_DATE" ]; then
  hook_date=${GIT_AUTHOR_DATE#@}
  hook_date=${hook_date% *}
  head_date=$(git log -1 --format=%at HEAD 2>/dev/null)
  if [ -n "$head_date" ] && [ "$hook_date" = "$head_date" ]; then
    head_sha=$(git rev-parse HEAD)
    on_main=false
    on_staging=false
    if git rev-parse --quiet --verify origin/main >/dev/null 2>&1; then
      git merge-base --is-ancestor "$head_sha" origin/main 2>/dev/null && on_main=true
    fi
    if git rev-parse --quiet --verify origin/staging >/dev/null 2>&1; then
      git merge-base --is-ancestor "$head_sha" origin/staging 2>/dev/null && on_staging=true
    fi
    if [ "$on_main" = "true" ] || [ "$on_staging" = "true" ]; then
      if [ -n "$REWRITE_OVERRIDE" ]; then
        echo ""
        echo "⚠️  REWRITE_OVERRIDE=$REWRITE_OVERRIDE — bypassing amend-of-pushed check (pre-commit heuristic)."
        echo ""
      else
        echo ""
        echo "❌ ERROR: Detected git commit --amend -m of a pushed commit."
        echo ""
        echo "   Commit being amended: $head_sha"
        echo "   Found on origin/main:    $on_main"
        echo "   Found on origin/staging: $on_staging"
        echo ""
        echo "   (Detected via GIT_AUTHOR_DATE matching HEAD's author date,"
        echo "   which is preserved on amend. False positive only if two real"
        echo "   commits within the same second target a pushed commit.)"
        echo ""
        echo "   Per apps/web/.claude/rules/git-and-deployment.md Rule 3:"
        echo "   Make a NEW commit instead. Fix-forward commits cost nothing."
        echo ""
        echo "   Override (rare, intentional history rewrite):"
        echo "     REWRITE_OVERRIDE=cleanup git commit --amend -m ..."
        echo ""
        exit 1
      fi
    fi
  fi
fi

cd apps/web
npx lint-staged
# tsc --noEmit catches TypeScript errors at commit time. Combined with
# `exactOptionalPropertyTypes` (enabled Session 80) this closes the
# Protocol 5 gap class where tsc-passes-but-next-build-fails type errors
# previously slipped to the pre-push hook (5-8 min cycle, history rewrite).
# The pre-push hook still runs `npm run build` as a backstop for the
# rare Next-only failures (SWC quirks, module-load errors during SSG).
npx tsc --noEmit
npx vitest run
